#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
cd "$SCRIPT_DIR"

source ./common.sh

if [ "$#" -lt 1 ]; then
    echo "Usage: $0 <ipmi_host> [<args>]" 1>&2
    exit 1
fi

SERVER="$1"
shift;

CREDENTIALS=$(rbw search "$SERVER" | head -n 1)
if [ -z "$CREDENTIALS" ]; then
    log fatal 'no credentials found for server' server "$SERVER"
fi
ssh venus5 ipmitool \
    -I lanplus \
    -H "$SERVER" \
    -U "$(rbw get --raw "$CREDENTIALS" | jq -r '.data.username | @sh')" \
    -P "$(rbw get --raw "$CREDENTIALS" | jq -r '.data.password | @sh')" \
    "$@"
