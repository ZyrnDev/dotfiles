#!/usr/bin/env bash
set -euo pipefail

source "$HOME/.local/bin/common.sh"

BW_SESSION_FILE="/run/user/$(id -u)/bw-session"

function bw() {
    flatpak run \
        --command=bw com.bitwarden.desktop \
        --session "$(cat "$BW_SESSION_FILE")" \
        "$@"
}

FAILURE_COUNT=0
function handle_auth_error() {
    FAILURE_COUNT=$((FAILURE_COUNT + 1))
    if [ $FAILURE_COUNT -ge 3 ]; then
        log fatal 'Bitwarden session is invalid after 3 attempts, exiting'
    else
        log error 'Bitwarden session is invalid, try again'
    fi
    true
}

while bw status | jq -e '.status != "unlocked"' > /dev/null; do
    rm -f "$BW_SESSION_FILE"
    touch "$BW_SESSION_FILE"
    chmod 600 "$BW_SESSION_FILE"
    bw unlock --raw >> "$BW_SESSION_FILE" \
        || handle_auth_error
done

bw "$@"
