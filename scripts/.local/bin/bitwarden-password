#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
source "$SCRIPT_DIR/common.sh"

if [ $# -ne 1 ]; then
    echo "Usage: $0 <search>"
    echo "Example: $0 venus5"
    exit 1
fi

function format_item_entry() {
    jq -r '"\(.key)) \(.value.login.username)@\(.value.name)"'
}

log info 'searching bitwarden...' query "$1"
ITEMS=$(bitwarden list items --search "$1")
case $(echo "$ITEMS" | jq -r 'length') in
    0)
        log fatal "no items found matching $1"
        ;;
    1)
        ITEM=$(echo "$ITEMS" | jq 'to_entries | .[0]' | format_item_entry)
        ;;
    *)
        ITEM=$(echo "$ITEMS" | jq 'to_entries | .[]' | format_item_entry | gum choose --header "multiple items found, select one:")
        ;;
esac

INDEX=$(echo "$ITEM" | cut -d ')' -f1)
ITEM=$(echo "$ITEMS" | jq -r --arg INDEX "$INDEX" 'to_entries | .[] | select(.key == ($INDEX|tonumber)) | .value')
NAME=$(echo "$ITEM" | jq -r '.name')
USERNAME=$(echo "$ITEM" | jq -r '.login.username')
log info 'retrieved password' username "$USERNAME" account "$NAME"
echo "$ITEM" | jq -r '.login.password' | xclip -in -selection clipboard
