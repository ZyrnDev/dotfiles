#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
source "$SCRIPT_DIR/common.sh"

if [ $# -eq 0 ]; then
    log info 'searching bitwarden...'
    ITEMS="$(rbw list)"
elif [ $# -eq 1 ]; then
    log info 'searching bitwarden...' query "$1"
    ITEMS=$(rbw search "$1")
else
    echo "Usage: $0 <search>"
    echo "Example: $0 venus5"
    exit 1
fi

case $(echo "$ITEMS" | wc -l) in
    0)
        log fatal "no items found matching $1"
        ;;
    1)
        ITEM=$(echo "$ITEMS")
        ;;
    *)
        ITEM=$(echo "$ITEMS" | gum filter --header "multiple items found, select one:")
        ;;
esac

echo "$ITEM"

USERNAME=$(rbw get --field username "$ITEM")
log info 'retrieved password' account "$ITEM" username "$USERNAME"
rbw get --clipboard --field password "$ITEM"
