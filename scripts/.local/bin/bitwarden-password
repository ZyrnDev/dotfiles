#!/usr/bin/env bash
set -euo pipefail

export GUM_LOG_LEVEL=info

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
source "$SCRIPT_DIR/common.sh"

SEARCH_TERM=
CLIPBOARD=false
WINDOW=false
WINDOW_ID=

for arg in "$@"; do
    case "$arg" in
        --clipboard)
            CLIPBOARD=true
            ;;
        --no-clipboard)
            CLIPBOARD=false
            ;;
        --window=*)
            WINDOW=true
            WINDOW_ID="${arg#*=}"
            ;;
        *)
            if [ -z "$SEARCH_TERM" ]; then
                SEARCH_TERM="$arg"
            else
                log fatal "unexpected argument" arg "$arg"
            fi
            ;;
    esac
done

if [ -z "$SEARCH_TERM" ]; then
    log info 'searching bitwarden...'
    ITEMS="$(rbw list)"
else
    log info 'searching bitwarden...' query "$SEARCH_TERM"
    ITEMS=$(rbw search "$SEARCH_TERM")
fi

case $(echo "$ITEMS" | wc -l) in
    0)
        log fatal "no items found matching $1"
        ;;
    1)
        ITEM=$(echo "$ITEMS")
        ;;
    *)
        ITEM=$(echo "$ITEMS" | gum filter --header "multiple items found, select one:")
        ;;
esac

USERNAME=$(rbw get --field username "$ITEM")
log info 'retrieved password' account "$ITEM" username "$USERNAME"

if [ "$CLIPBOARD" = true ]; then
    rbw get --clipboard --field password "$ITEM"
fi

if [ "$WINDOW" = true ]; then
    if [ -z "$WINDOW_ID" ]; then
        log fatal "window id must be provided when --window is used"
    fi

    log debug "focusing window" window_id "$WINDOW_ID"
    xdotool windowactivate "$WINDOW_ID"

    log debug "typing password into window" window_id "$WINDOW_ID"
    xdotool type --delay 100 --clearmodifiers --file <(rbw get --field password "$ITEM" | tr --delete '\n')
fi

if [ "$CLIPBOARD" != true ] && [ "$WINDOW" != true ]; then
    rbw get --field password "$ITEM"
fi
