#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
cd "$SCRIPT_DIR"

source ./common.sh

if [ "$#" -ne 1 ] && [ "$#" -ne 2 ]; then
    echo "Usage: $0 <ipmi_host> [<boot_device>]" 1>&2
    exit 1
fi

SERVER="$1"
if [ "$#" -eq 2 ]; then
  export BOOT_DEVICE="$2"
fi

POWER_STATE=`ipmi $SERVER chassis power status | cut -d ' ' -f 4`
BOOTDEV=`
    ipmi $SERVER chassis bootdev 2>&1 \
      | grep ':' | cut -d':' -f1 | trim \
      | prompt_choice BOOT_DEVICE --header "select a bootdev for the next boot of $SERVER"
`

if [ "$POWER_STATE" != "on" ]; then
    log fatal 'chassis in unexpected state' server "$SERVER" state "$POWER_STATE"
fi

ipmi $SERVER chassis bootdev "$BOOTDEV"
ipmi $SERVER chassis power cycle
