Host bitbucket.org
  User git
  IdentityFile ~/.ssh/mitchell@canopusnet.com

Host canopus-bastion
    LocalForward 1443 mercury2-ipmi.canopusnet.dev:443
    LocalForward 3000 mercury2.canopusnet.dev:3000

# Canopus SSH Bastion for Internal (not tailscale) Servers
Host canopus-bastion
    HostName wedge-5
    User canopus

# UNSW - Canopus Joint Servers
Host dumble
    HostName dumble.sdn.unsw.edu.au
    User canopus
    ProxyJump canopus-bastion

# Canopus Standard Ubuntu Servers
Host venus5
#    HostName %h.canopusnet.dev
    User canopus

# Canopus Standard Ubuntu Internal Servers
Host mercury2 mercury3
    HostName %h.canopusnet.dev
    User canopus
    ProxyJump canopus-bastion

# Canopus OS Internal Servers
Host ares1 ares3
    HostName %h.canopusnet.dev
    User operator
    IdentityFile ~/.ssh/rescue@canopus-os
    ProxyJump canopus-bastion

Host ceres
    HostName %h.canopusnet.dev
    User operator
    ProxyJump canopus-bastion

Host unsw-gcp-test-vm
    HostName gce-instance-n-snflow-unsw-gcp-test-analytics-vm-0
    User canopus

Host unsw-ipmi-library
#    HostName 129.94.2.159
    HostName omb-analytics-srv01
    User operator
#    LocalForward 1443 129.94.2.136:443
#    LocalForward 2068 129.94.2.136:2068
    LocalForward 1443 172.19.5.211:443
    LocalForward 2068 172.19.5.211:2068

Host unsw-ipmi-omb
#    HostName 129.94.2.158
    HostName unsw-library-analytics-srv01
    User operator
#    LocalForward 1443 129.94.2.138:443
#    LocalForward 2068 129.94.2.138:2068
    LocalForward 1443 172.19.5.212:443
    LocalForward 2068 172.19.5.212:2068

Host unsw-library omb
    HostName %h-analytics-srv01
#    HostName 100.86.16.46
#    HostName 129.94.2.158
#    HostName 129.94.2.159
#    HostName omb-analytics-srv01
    User operator
    LocalForward 6006 localhost:6006

